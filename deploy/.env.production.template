# Copy to /var/www/PriceAIAly/.env on the server and fill real values.
# Required for full features. ADMIN_PASSWORD throws at runtime if unset.

# --- Supabase (required for live data + admin) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin auth ---
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_VERSION=1

# --- Cron / collectors ---
CRON_SECRET=
CRON_PUBLIC_BASE_URL=

# --- Optional analytics / webhooks (leave blank if unused) ---
PRICEAI_ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
